# ============================================
# AI Job Search - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --------------------------------------------
# n8n Configuration
# --------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_USER_EMAIL=admin@example.com
N8N_USER_PASSWORD=changeme_password_here
WEBHOOK_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://n8n:5678/webhook/

# --------------------------------------------
# PostgreSQL Database (for n8n)
# --------------------------------------------
POSTGRES_PASSWORD=n8npassword_change_this
POSTGRES_USER=n8n
POSTGRES_DB=n8n

# --------------------------------------------
# AI Job Search API Configuration
# --------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
PROFILE_PATH=/app/data/structures/perfil.md
OUTPUT_PATH=/app/output
TZ=UTC

# --------------------------------------------
# WhatsApp Gateway Configuration
# --------------------------------------------
# Option 1: Use internal whatsapp-web.js gateway
WHATSAPP_USE_INTERNAL=true
WHATSAPP_API_URL=http://whatsapp:3000
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_here

# Option 2: Use external WhatsApp service (Twilio, etc.)
# WHATSAPP_USE_INTERNAL=false
# WHATSAPP_EXTERNAL_API_URL=https://api.twilio.com/2010-04-01/...
# WHATSAPP_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHATSAPP_AUTH_TOKEN=your_auth_token

# --------------------------------------------
# Email Configuration (for sending CVs)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_NAME=AI Job Search
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_TLS=true

# --------------------------------------------
# Cloud Storage Configuration (Optional)
# --------------------------------------------
# Options: local, s3, gdrive
STORAGE_PROVIDER=local

# AWS S3 (if STORAGE_PROVIDER=s3)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_ENDPOINT_URL=  # Leave empty for AWS, set for MinIO/etc

# Google Drive (if STORAGE_PROVIDER=gdrive)
# GDRIVE_FOLDER_ID=your-folder-id-here
# GDRIVE_CREDENTIALS_PATH=/app/data/gdrive-credentials.json

# --------------------------------------------
# Oh My Pi Configuration (Optional)
# --------------------------------------------
# If using external Oh My Pi instance for agents
# OH_MY_PI_USE_EXTERNAL=false
# OH_MY_PI_API_URL=http://oh-my-pi:8080
# OH_MY_PI_API_KEY=your_api_key_here

# --------------------------------------------
# Job Portal Configuration
# --------------------------------------------
# List of portals to search (comma-separated)
# Options: jobindex, jobnet, jobbank, jobdanmark, linkedin
ENABLED_PORTALS=jobindex,jobnet,linkedin

# Default search queries (can be overridden via webhook)
DEFAULT_SEARCH_QUERIES=["Python Developer","Data Engineer","Software Developer"]

# Default locations
DEFAULT_LOCATIONS=["Remote","Copenhagen","Madrid"]

# Fit score threshold (jobs below this won't be sent)
DEFAULT_FIT_THRESHOLD=70

# --------------------------------------------
# Application Settings
# --------------------------------------------
# Maximum number of jobs to process per run
MAX_JOBS_PER_RUN=50

# Time to wait for user approval (in hours)
APPROVAL_TIMEOUT_HOURS=48

# Auto-apply if score is above this (0 to disable)
AUTO_APPLY_THRESHOLD=0  # Set to 90+ for auto-apply on perfect matches

# --------------------------------------------
# Monitoring & Logging
# --------------------------------------------
SENTRY_DSN=  # Optional: https://sentry.io/ for error tracking
METRICS_ENABLED=false
PROMETHEUS_PORT=9090

# --------------------------------------------
# Security
# --------------------------------------------
# API authentication token (for webhook calls from n8n)
API_AUTH_TOKEN=generate_a_secure_token_here

# JWT secret for session management
JWT_SECRET_KEY=generate_another_secure_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5678,http://localhost:3000

# --------------------------------------------
# Timezone
# --------------------------------------------
TZ=UTC  # Change to your timezone (e.g., Europe/Madrid, America/New_York)